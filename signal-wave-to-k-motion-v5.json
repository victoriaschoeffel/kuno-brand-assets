{
  "name": "kuno-signal-wave-to-k-motion-v5",
  "version": "0.15",
  "format": "kuno-motion-spec-v1",
  "description": "Signal bars with a hinge seed that resolves into a fully joined right-opening K during capture.",
  "palette": {
    "paper": "#F4EFE6",
    "ink": "#1C1A17",
    "quiet": "#E6DFD2",
    "stone": "#7A736A",
    "softNickel": "#A7A19A"
  },
  "viewBox": {
    "width": 220,
    "height": 220,
    "cornerRadius": 44,
    "safeInset": 28
  },
  "timing": {
    "durationMs": 1600,
    "curve": "cubic-bezier(0.2, 0.74, 0.18, 1)",
    "loopForReview": true,
    "productionTrigger": "capture-state-only"
  },
  "bars": [
    {
      "id": "spine",
      "role": "fixed K spine and first signal bar",
      "fill": "paper"
    },
    {
      "id": "hinge",
      "role": "small signal seed that becomes the K bridge",
      "fill": "paper"
    },
    {
      "id": "center",
      "role": "neutral signal bead",
      "fill": "softNickel"
    },
    {
      "id": "upper",
      "role": "right signal bar becoming upper K arm",
      "fill": "paper"
    },
    {
      "id": "lower",
      "role": "hidden paired bar becoming lower K arm",
      "fill": "paper"
    },
    {
      "id": "tip",
      "role": "outer signal rail that fades during K reveal",
      "fill": "stone"
    }
  ],
  "keyframes": [
    {
      "name": "idleSignal",
      "t": 0,
      "label": "0ms connected signal",
      "bars": {
        "spine": { "x": 48, "y": 54, "w": 22, "h": 112, "r": 0, "opacity": 1 },
        "hinge": { "x": 66, "y": 101, "w": 24, "h": 20, "r": 0, "opacity": 0.95 },
        "center": { "x": 103, "y": 86, "w": 16, "h": 48, "r": 0, "opacity": 1 },
